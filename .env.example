# =============================================
# Wrap Up AI - Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# Database (PostgreSQL)
# Get this from Railway: your project → database → Connect
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini AI (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# KITCHEN CLONE cost guard — shared secret protecting /api/generate from
# random/bot hits burning Gemini credits. The server FAILS CLOSED: if
# KITCHEN_TEST_SECRET is unset, /api/generate returns 403 for everyone.
# VITE_KITCHEN_TEST_SECRET must equal KITCHEN_TEST_SECRET and is baked into
# the client bundle at BUILD time (pass it as a Docker build arg, like
# VITE_TURNSTILE_SITE_KEY). Note: a build-time client value is visible in the
# JS bundle — it blocks bots/crawlers, not a determined human.
KITCHEN_TEST_SECRET=set_a_long_random_value_here
VITE_KITCHEN_TEST_SECRET=set_to_the_same_value_as_KITCHEN_TEST_SECRET

# Stripe Payments (from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Session security (generate a random string, e.g. openssl rand -base64 32)
SESSION_SECRET=change_this_to_a_random_secret_string

# Admin panel password
ADMIN_PASSWORD=your_admin_password_here

# App environment
NODE_ENV=production
PORT=5000

# MaxMind GeoLite2 (Item 0b — city-level geo capture on renders)
# Required at runtime for server boot to download the GeoLite2-City.mmdb
# database (~70 MB) from MaxMind. Sign up free at https://www.maxmind.com/en/geolite2/signup,
# then generate a license key under "Manage License Keys". Both vars must
# be set on Railway as service variables (runtime only — NOT build args).
MAXMIND_ACCOUNT_ID=your_maxmind_account_id_here
MAXMIND_LICENSE_KEY=your_maxmind_license_key_here
